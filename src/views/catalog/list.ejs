<%- include('../partials/header') %>

<main>
  <p>
    Browse our available courses and click on any course to see detailed information including
    available sections and instructors.
  </p>

  <div class="course-list">
    <% Object.keys(courses).forEach(id => { 
         const course = courses[id]; 
    %>
      <div class="course-card">
        <h3>
          <a href="/catalog/<%= course.id %>">
            <%= course.id %> — <%= course.title %>
          </a>
        </h3>

        <p class="course-id">
          <%= course.id %> • <%= course.credits %> credits
        </p>

        <% if (course.department) { %>
          <p class="course-department"><%= course.department %></p>
        <% } %>

        <% if (course.description) { %>
          <p class="course-description"><%= course.description %></p>
        <% } %>
      </div>
    <% }) %>
  </div>
</main>

<%- include('../partials/footer') %>